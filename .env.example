APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Mobile Money — mock (démo) ou flexpay (RDC : https://flexpay.cd)
MOBILE_MONEY_DRIVER=mock
FLEXPAY_API_KEY=
FLEXPAY_MERCHANT_ID=
FLEXPAY_CURRENCY=CDF
# URL publique du webhook (HTTPS en production)
FLEXPAY_CALLBACK_URL="${APP_URL}/webhooks/flexpay"
# Optionnel : header X-Webhook-Secret attendu sur /webhooks/flexpay
FLEXPAY_WEBHOOK_SECRET=

SHWARY_MERCHANT_ID=
SHWARY_MERCHANT_KEY=
SHWARY_COUNTRY=DRC
SHWARY_CURRENCY=CDF
SHWARY_SANDBOX=true
SHWARY_MIN_AMOUNT_CDF=2900
SHWARY_BASE_URL=
SHWARY_PAYMENT_URL=
SHWARY_TRANSACTION_URL=
SHWARY_CALLBACK_URL="${APP_URL}/webhooks/shwary"
SHWARY_WEBHOOK_SECRET=

# OpenAI Configuration for Advanced OCR Scanner
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Python PaddleOCR + OpenAI microservice
# Local default for development. On Render, point these to the public URL of the separate OCR service.
OCR_PYTHON_URL=http://127.0.0.1:8010/scan-plaque
OCR_PYTHON_HEALTH_URL=http://127.0.0.1:8010/health
OCR_PYTHON_TIMEOUT=180
OCR_PYTHON_CONNECT_TIMEOUT=10
OCR_PYTHON_USE_OPENAI=true

# Tesseract Configuration (fallback OCR)
TESSERACT_PATH=/usr/bin/tesseract
